<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <!-- Brand accent (Cursor Violet) drives framework accent surfaces. -->
        <item name="android:colorAccent">@color/cursor_violet</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:navigationBarColor">@color/launcher_bg</item>
        <item name="android:statusBarColor">@color/launcher_bg</item>
        <item name="android:windowBackground">@color/launcher_bg</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>

    <style name="TeclasHomeTheme" parent="@style/AppTheme">
        <item name="android:windowShowWallpaper">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>
