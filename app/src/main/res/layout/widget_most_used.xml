<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/most_used_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_most_used_bg"
    android:padding="10dp">

    <TextView
        android:id="@+id/most_used_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MOST USED"
        android:textSize="9sp"
        android:letterSpacing="0.22"
        android:typeface="monospace"
        android:textColor="#8AFFFFFF"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/most_used_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LAUNCH SOME APPS FIRST"
        android:textSize="9sp"
        android:letterSpacing="0.12"
        android:typeface="monospace"
        android:textColor="#55FFFFFF"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/most_used_row1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView android:id="@+id/icon_0" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:scaleType="fitCenter" />
        <ImageView android:id="@+id/icon_1" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:scaleType="fitCenter" />
        <ImageView android:id="@+id/icon_2" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:scaleType="fitCenter" />
        <ImageView android:id="@+id/icon_3" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:scaleType="fitCenter" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/most_used_row2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView android:id="@+id/icon_4" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:scaleType="fitCenter" />
        <ImageView android:id="@+id/icon_5" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:scaleType="fitCenter" />
        <ImageView android:id="@+id/icon_6" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:scaleType="fitCenter" />
        <ImageView android:id="@+id/icon_7" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:scaleType="fitCenter" />
    </LinearLayout>
</LinearLayout>
