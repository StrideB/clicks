<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="2dp" android:top="12dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#66000000" />
        </shape>
    </item>
    <item android:top="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#04060A" />
        </shape>
    </item>
    <item android:top="6dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#070910" />
        </shape>
    </item>
    <item android:top="4dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#0B0E14" />
        </shape>
    </item>
    <item android:bottom="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <gradient android:angle="270" android:startColor="#333844" android:centerColor="#23262E" android:centerY="0.40" android:endColor="#101319" />
            <stroke android:width="1dp" android:color="#05060A" />
        </shape>
    </item>
    <item android:bottom="8dp" android:height="1dp" android:gravity="top">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="12dp" android:topRightRadius="12dp" />
            <solid android:color="#24FFFFFF" />
        </shape>
    </item>
    <item android:left="5dp" android:top="2dp" android:right="5dp" android:bottom="26dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="9dp" android:topRightRadius="9dp" android:bottomLeftRadius="18dp" android:bottomRightRadius="18dp" />
            <gradient android:angle="270" android:startColor="#17FFFFFF" android:centerColor="#05FFFFFF" android:centerY="0.56" android:endColor="#00FFFFFF" />
        </shape>
    </item>
    <item android:left="2dp" android:top="28dp" android:right="2dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <corners android:bottomLeftRadius="12dp" android:bottomRightRadius="12dp" />
            <gradient android:angle="90" android:startColor="#8A000000" android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
