<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.SET_WALLPAPER" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />
    <!-- Spaces prediction: detect car kit / headphones as a context trigger. Runtime-requested
         only when the user enables a Bluetooth trigger in Spaces settings; everything degrades
         gracefully without it. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Spaces: actionable "Is this Home?" suggestion notifications (runtime on 33+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/AppTheme">
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <service
            android:name=".TeclasNotificationListener"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <service
            android:name=".DockedKeyboardService"
            android:enabled="true"
            android:exported="false" />

        <activity
            android:name=".ImeSettingsActivity"
            android:exported="true"
            android:label="Teclas Keyboard"
            android:theme="@style/AppTheme" />

        <activity
            android:name=".AgenticSkillsActivity"
            android:exported="true"
            android:label="Skills"
            android:theme="@style/AppTheme" />

        <receiver
            android:name=".predict.PlaceSuggestionReceiver"
            android:exported="false" />

        <activity
            android:name=".SpacesSettingsActivity"
            android:exported="true"
            android:label="Spaces"
            android:theme="@style/AppTheme" />

        <activity
            android:name=".grid.GridWorkspaceActivity"
            android:exported="false"
            android:label="Grid Workspace"
            android:launchMode="singleTask"
            android:theme="@style/GridHomeTheme"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation|keyboardHidden|uiMode" />

        <!-- Optional HOME entry for the grid workspace. Disabled by default; the settings
             toggle flips it on via PackageManager so the user can pick it as default home. -->
        <activity-alias
            android:name=".grid.GridHomeAlias"
            android:targetActivity=".grid.GridWorkspaceActivity"
            android:exported="true"
            android:enabled="false"
            android:icon="@mipmap/ic_launcher"
            android:label="Teclas Grid">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity-alias>

        <receiver
            android:name=".MostUsedAppsWidget"
            android:exported="true"
            android:label="Teclas · Most Used">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_most_used_info" />
        </receiver>

        <activity
            android:name=".AttachPickerActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <service
            android:name=".TeclasImeService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/teclas_input_method" />
        </service>

        <service
            android:name=".InputInjectionService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation|keyboardHidden|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- Spotify OAuth PKCE redirect -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.fran.teclas" android:host="spotify-callback" />
            </intent-filter>
            <!-- Gmail OAuth PKCE redirect. Replace the scheme below with the reversed form
                 of your Google iOS OAuth client ID: com.googleusercontent.apps.<SUFFIX> -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.googleusercontent.apps.YOUR_IOS_CLIENT_ID" />
            </intent-filter>
        </activity>
        <activity-alias
            android:name=".TeclasAppEntry"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
    </application>
</manifest>
